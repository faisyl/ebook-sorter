FROM python:3.12-alpine AS builder

WORKDIR /build

RUN apk add --no-cache gcc musl-dev libxml2-dev libxslt-dev

COPY pyproject.toml .
COPY src/ src/

RUN pip install --no-cache-dir build && \
    python -m build --wheel --outdir /build/dist


FROM python:3.12-alpine

LABEL org.opencontainers.image.source="https://github.com/faisyl/ebook-sorter"

RUN apk add --no-cache \
        tesseract-ocr \
        djvulibre \
        p7zip \
        su-exec \
        libxml2 \
        libxslt \
        gcc \
        musl-dev \
        libxml2-dev \
        libxslt-dev \
    && true

COPY --from=builder /build/dist/*.whl /tmp/
RUN pip install --no-cache-dir /tmp/*.whl && rm /tmp/*.whl

RUN apk del gcc musl-dev libxml2-dev libxslt-dev

COPY <<'EOF' /entrypoint.sh
#!/bin/sh
if [ -n "$PUID" ] && [ -n "$PGID" ]; then
    addgroup -g "$PGID" ebook 2>/dev/null
    adduser -u "$PUID" -G ebook -D ebook 2>/dev/null
    exec su-exec ebook ebook-sorter "$@"
else
    exec ebook-sorter "$@"
fi
EOF
RUN chmod +x /entrypoint.sh

WORKDIR /data

ENTRYPOINT ["/entrypoint.sh"]
